{
  "expo": {
    "scheme": "macropal",
    "name": "Macro Pal",
    "slug": "macro-buddy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#fff7ed"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.macrobuddy.app",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Macro Pal uses speech recognition to let you log food by speaking naturally.",
        "NSMicrophoneUsageDescription": "Macro Pal needs microphone access to convert your speech to text for food logging.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#fff7ed"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.macrobuddy.app",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-speech-recognition",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      "@sentry/react-native"
    ],
    "extra": {
      "eas": {
        "projectId": "d5461aec-e93b-4063-99ef-2fcf7ef376e0"
      }
    },
    "owner": "nedweingart"
  }
}
